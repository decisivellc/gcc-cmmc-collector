{
  "tenant_id": "YOUR_TENANT_ID_HERE",
  "client_id": "YOUR_APP_ID_HERE",
  "client_secret": "YOUR_CLIENT_SECRET_HERE",
  "authority": "https://login.microsoftonline.us",
  "graph_base_url": "https://graph.microsoft.us/v1.0",
  "reporting": {
    "output_path": "./reports",
    "format": "html",
    "generate_json": true,
    "generate_remediation_backlog": true
  },
  "collectors": {
    "azure_ad": {
      "enabled": true,
      "inactivity_threshold_days": 30
    },
    "intune": {
      "enabled": true,
      "device_sync_threshold_days": 30,
      "filter_os": "macOS"
    },
    "defender": {
      "enabled": true,
      "vulnerability_threshold_severity": "high"
    },
    "exchange": {
      "enabled": true
    },
    "policies": {
      "enabled": true,
      "site_url": "",
      "comment": "Paste the URL of your SharePoint policy document library (the Forms/AllItems.aspx page works). Examples: https://contoso.sharepoint.us/IT%20Policies/Forms/AllItems.aspx or https://contoso.sharepoint.us/sites/Compliance/Shared%20Documents/Forms/AllItems.aspx. Leave empty to skip."
    }
  },
  "schedule": {
    "type": "on_demand",
    "comment": "Set to 'weekly' if running via GitHub Actions"
  }
}
